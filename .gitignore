# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets
.env

# Large binary files
*.pdf

# Source dictionaries (downloaded at build time)
data/dictionaries/it_full.txt
data/dictionaries/morph-it_048.txt

# OCR per-page progress (resume state)
data/ocr_*_pages/

# Scratch / auto-generated
main.py

# Backups
*.bak

# Stray downloaded images in project root
/*.jpg

# LLM cleanup cache (transient, regenerable via --batch --llm-cleanup)
state/llm_cleaned/
state/_llm_cleaned.stale-2026-04-03/
state/llm_batch.json

# Claude Code local settings
.claude/

# Throwaway typeface decision specimens (repo-root scratch; one loads a commercial demo font via CDN)
type-specimen*.html

# Drop-cap analysis sheets (large glyph/context measurement scratch, regenerable)
docs/assets/dropcaps/

# Divergence-audit candidate manifests (regenerable via audit_divergences.py)
state/audit/

# Comprehension-review collection (intention-review stage 1; raw model reads + ledger)
state/comprehension/

# Scan re-adjudication cache (Gemini-primary vision reviewer; per-chapter, regenerable)
state/readjudication/

# Residual-error sampling estimate cache (per-page blind reads + adjudications, regenerable)
state/sample_estimate/

# Page-concordance cache (folio reads + audit sheet/images; regenerable via build_concordance.py)
state/concordance/

# Harvard/Google copy scans rendered from the PDF (Copy B; regenerable via vision_review)
assets/page_images_harvard/
